#!/bin/bash
# md2pdf macOS app launcher
# Accepts .md files via drag-and-drop or open-with

DIR="$(cd "$(dirname "$0")/../Resources" && pwd)"
FONT_DIR="$DIR/fonts"
LOG="/tmp/md2pdf.log"
> "$LOG"  # clear the log

# Use the symlink or the local copy of md2pdf.py
if [ -L "$DIR/md2pdf.py" ] && [ -f "$(readlink "$DIR/md2pdf.py")" ]; then
    SCRIPT="$(readlink -f "$DIR/md2pdf.py")"
elif [ -f "$DIR/md2pdf.py" ]; then
    SCRIPT="$DIR/md2pdf.py"
else
    osascript -e 'display alert "md2pdf: Error" message "md2pdf.py not found in Resources" as critical'
    exit 1
fi

# --- Python ---
PYTHON="/usr/bin/python3"
if [ ! -x "$PYTHON" ]; then
    PYTHON="$(command -v python3 2>/dev/null)"
fi
if [ -z "$PYTHON" ] || [ ! -x "$PYTHON" ]; then
    osascript -e 'display alert "md2pdf: Error" message "python3 not found. Install the Command Line Tools:\n\nxcode-select --install" as critical'
    exit 1
fi

# On Apple Silicon, force arm64 so pip packages match the interpreter
if [ "$(uname -m)" = "arm64" ]; then
    PYTHON_CMD=(arch -arm64 "$PYTHON")
else
    PYTHON_CMD=("$PYTHON")
fi

# --- Check / install reportlab ---
"${PYTHON_CMD[@]}" -c "import reportlab" 2>/dev/null
if [ $? -ne 0 ]; then
    CHOICE=$(osascript -e 'button returned of (display alert "md2pdf: reportlab not found" message "The reportlab module is required. Install automatically?" buttons {"Cancel", "Install"} default button "Install" as warning)')
    if [ "$CHOICE" = "Install" ]; then
        osascript -e 'display notification "Installing reportlab..." with title "md2pdf"'
        INSTALL_OUT=$("${PYTHON_CMD[@]}" -m pip install --user reportlab 2>&1)
        if [ $? -ne 0 ]; then
            osascript -e "display alert \"md2pdf: Install error\" message \"$(echo "$INSTALL_OUT" | tail -5)\" as critical"
            exit 1
        fi
        osascript -e 'display notification "reportlab installed!" with title "md2pdf" sound name "Glass"'
    else
        exit 0
    fi
fi

# --- Check / install matplotlib (optional, for charts) ---
"${PYTHON_CMD[@]}" -c "import matplotlib" 2>/dev/null
if [ $? -ne 0 ]; then
    CHOICE=$(osascript -e 'button returned of (display alert "md2pdf: matplotlib not found" message "The matplotlib module is needed for charts (```chart). Install? Without it charts are replaced with placeholders." buttons {"Skip", "Install"} default button "Install" as warning)')
    if [ "$CHOICE" = "Install" ]; then
        osascript -e 'display notification "Installing matplotlib..." with title "md2pdf"'
        INSTALL_OUT=$("${PYTHON_CMD[@]}" -m pip install --user matplotlib 2>&1)
        if [ $? -ne 0 ]; then
            osascript -e "display alert \"md2pdf: matplotlib install error\" message \"$(echo "$INSTALL_OUT" | tail -5)\" as warning"
        else
            osascript -e 'display notification "matplotlib installed!" with title "md2pdf" sound name "Glass"'
        fi
    fi
fi

# --- Input files ---
if [ $# -eq 0 ]; then
    FILES=$(osascript -e '
        set mdFiles to choose file with prompt "Choose Markdown files:" of type {"md", "markdown", "txt"} with multiple selections allowed
        set posixPaths to ""
        repeat with f in mdFiles
            set posixPaths to posixPaths & POSIX path of f & linefeed
        end repeat
        return posixPaths
    ' 2>/dev/null)

    if [ -z "$FILES" ]; then
        exit 0
    fi

    set --
    while IFS= read -r line; do
        [ -n "$line" ] && set -- "$@" "$line"
    done <<< "$FILES"
fi

[ $# -eq 0 ] && exit 0

# --- Settings dialog (native Cocoa, fallback to AppleScript) ---
if [ -x "$DIR/settings_gui" ]; then
    SETTINGS=$("$DIR/settings_gui" "$@" 2>/dev/null)
else
    SETTINGS=$(osascript "$DIR/settings_dialog.applescript" "$@" 2>/dev/null)
fi

if [ -z "$SETTINGS" ] || [ "$SETTINGS" = "CANCEL" ]; then
    exit 0
fi

# Validation: expect 31 fields (30 separators)
FIELD_COUNT=$(echo "$SETTINGS" | tr -cd '|' | wc -c | tr -d ' ')
if [ "$FIELD_COUNT" -lt 29 ]; then
    osascript -e 'display alert "md2pdf: Error" message "Invalid response from the settings dialog" as critical'
    exit 1
fi

# Parse: theme|...|copyId|authorOnCover|coverPattern|fileOrder
IFS='|' read -r THEME COVER TOC WATERMARK SUBTITLE OPEN_PDF OUTPUT_DIR AUTHOR COVER_IMAGE CUSTOM_THEME TOC_DEPTH MARGINS PAGE_SIZE TEMPLATE HTML_TOO DOC_TITLE COVER_TOP MERGE_MODE H1_TITLES IMAGE_DIR DUPLEX H2_BREAK JUSTIFY LINE_NUMBERS RENUMBER CHAPTER_PAGE QR COPY_ID AUTHOR_ON_COVER COVER_PATTERN FILE_ORDER <<< "$SETTINGS"

# --- Converter arguments ---
ARGS=("--font-dir" "$FONT_DIR" "--theme" "$THEME")

[ "$COVER" = "no" ] && ARGS+=("--no-cover")
[ "$TOC" = "no" ] && ARGS+=("--no-toc")
[ -n "$TOC_DEPTH" ] && ARGS+=("--toc-depth" "$TOC_DEPTH")

if [ -z "$WATERMARK" ]; then
    ARGS+=("--no-watermark")
else
    ARGS+=("--watermark" "$WATERMARK")
fi

[ -n "$SUBTITLE" ] && ARGS+=("--subtitle" "$SUBTITLE")
[ -n "$AUTHOR" ] && ARGS+=("--author" "$AUTHOR")
[ "$AUTHOR_ON_COVER" = "no" ] && ARGS+=("--no-cover-author")
[ -n "$COVER_PATTERN" ] && [ "$COVER_PATTERN" != "circles" ] && ARGS+=("--cover-pattern" "$COVER_PATTERN")

# Duplex
[ "$DUPLEX" = "yes" ] && ARGS+=("--duplex")

# Cover with image
if [ -n "$COVER_IMAGE" ] && [ -f "$COVER_IMAGE" ]; then
    ARGS+=("--cover-image" "$COVER_IMAGE")
fi

# Custom theme
if [ "$THEME" = "custom" ] && [ -n "$CUSTOM_THEME" ] && [ -f "$CUSTOM_THEME" ]; then
    ARGS+=("--custom-theme" "$CUSTOM_THEME")
fi

# Margins
[ -n "$MARGINS" ] && ARGS+=("--margins" "$MARGINS")

# Page size
[ -n "$PAGE_SIZE" ] && ARGS+=("--page-size" "$PAGE_SIZE")

# Template
[ -n "$TEMPLATE" ] && ARGS+=("--template" "$TEMPLATE")

# Also produce an HTML version
[ "$HTML_TOO" = "yes" ] && ARGS+=("--html")

# Custom title
[ -n "$DOC_TITLE" ] && ARGS+=("--title" "$DOC_TITLE")

# Cover super-title
[ -n "$COVER_TOP" ] && ARGS+=("--cover-top" "$COVER_TOP")

# Image directory
[ -n "$IMAGE_DIR" ] && [ -d "$IMAGE_DIR" ] && ARGS+=("--image-dir" "$IMAGE_DIR")

# H2 break behavior
[ -n "$H2_BREAK" ] && ARGS+=("--h2-break" "$H2_BREAK")

# Justify / line numbers
[ "$JUSTIFY" = "no" ] && ARGS+=("--no-justify")
[ "$LINE_NUMBERS" = "no" ] && ARGS+=("--no-line-numbers")

# Merge options (passed only in merge mode)
if [ "$MERGE_MODE" = "yes" ]; then
    [ "$RENUMBER" = "yes" ] && ARGS+=("--renumber")
    [ "$CHAPTER_PAGE" = "yes" ] && ARGS+=("--chapter-page")
    [ -n "$FILE_ORDER" ] && ARGS+=("--no-sort")
fi

# QR code and copy ID
[ "$QR" = "yes" ] && ARGS+=("--qr")
[ "$COPY_ID" = "yes" ] && ARGS+=("--copy-id")

# --- Conversion ---
SUCCESS=0
FAIL=0
PDF_FILES=()
ERRORS=""

show_progress() {
    local current=$1 total=$2 filename=$3
    osascript -e "display notification \"[$current/$total] $filename\" with title \"md2pdf\"" 2>/dev/null &
}

# Collect cleaned-up paths
CLEAN_FILES=()
for FILE in "$@"; do
    # URL-decode only for file:// URI (Finder drag-drop)
    if [[ "$FILE" == file://* ]]; then
        FILE="${FILE#file://}"
        FILE=$(printf '%b' "${FILE//%/\\x}")
    fi
    if [ -f "$FILE" ]; then
        CLEAN_FILES+=("$FILE")
    else
        FAIL=$((FAIL + 1))
        ERRORS="$ERRORS\nNot found: $(basename "$FILE")"
    fi
done

# If the GUI provided a custom file order, use it
if [ -n "$FILE_ORDER" ]; then
    CLEAN_FILES=()
    TMPFO="$FILE_ORDER"
    while [ -n "$TMPFO" ]; do
        case "$TMPFO" in
            *"<>"*)
                F="${TMPFO%%<>*}"
                TMPFO="${TMPFO#*<>}"
                ;;
            *)
                F="$TMPFO"
                TMPFO=""
                ;;
        esac
        [ -n "$F" ] && [ -f "$F" ] && CLEAN_FILES+=("$F")
    done
fi

if [ "$MERGE_MODE" = "yes" ] && [ ${#CLEAN_FILES[@]} -ge 1 ]; then
    # --- Merge mode ---
    FIRST_FILE="${CLEAN_FILES[0]}"
    FIRST_BASENAME=$(basename "$FIRST_FILE")
    FIRST_NOEXT="${FIRST_BASENAME%.*}"

    # Output filename: --title if set, otherwise "merged"
    if [ -n "$DOC_TITLE" ]; then
        MERGE_NAME=$(echo "$DOC_TITLE" | sed 's/[\/\\:*?"<>|]/_/g')
    else
        MERGE_NAME="merged"
    fi

    if [ -n "$OUTPUT_DIR" ] && [ -d "$OUTPUT_DIR" ]; then
        OUTPUT="$OUTPUT_DIR/$MERGE_NAME.pdf"
    else
        OUTPUT="$(dirname "$FIRST_FILE")/$MERGE_NAME.pdf"
    fi

    # H1 titles (;;;-separated)
    H1_ARGS=()
    if [ -n "$H1_TITLES" ]; then
        HAS_TITLES=false
        remaining="$H1_TITLES"
        TITLE_LIST=()
        while [ -n "$remaining" ]; do
            title="${remaining%%;;;*}"
            TITLE_LIST+=("$title")
            [ -n "$title" ] && HAS_TITLES=true
            [ "$title" = "$remaining" ] && break
            remaining="${remaining#*;;;}"
        done
        if [ "$HAS_TITLES" = true ]; then
            # Drop empty trailing entries (not needed for positional mapping)
            while [ ${#TITLE_LIST[@]} -gt 0 ] && [ -z "${TITLE_LIST[${#TITLE_LIST[@]}-1]}" ]; do
                unset 'TITLE_LIST[${#TITLE_LIST[@]}-1]'
            done
            if [ ${#TITLE_LIST[@]} -gt 0 ]; then
                H1_ARGS=("--h1-titles")
                for T in "${TITLE_LIST[@]}"; do
                    H1_ARGS+=("$T")
                done
            fi
        fi
    fi

    osascript -e "display notification \"Merging ${#CLEAN_FILES[@]} files...\" with title \"md2pdf\"" 2>/dev/null &

    CONVERT_ERR=$("${PYTHON_CMD[@]}" "$SCRIPT" "${CLEAN_FILES[@]}" --merge -o "$OUTPUT" "${ARGS[@]}" "${H1_ARGS[@]}" 2>&1)

    if [ $? -eq 0 ]; then
        SUCCESS=1
        PDF_FILES+=("$OUTPUT")
    else
        FAIL=1
        LAST_ERR=$(echo "$CONVERT_ERR" | grep -E "(Error|Traceback)" | tail -1)
        [ -z "$LAST_ERR" ] && LAST_ERR=$(echo "$CONVERT_ERR" | tail -1)
        ERRORS="$ERRORS\nMerge: $LAST_ERR"
    fi
    echo "$CONVERT_ERR" >> "$LOG"
else
    # --- Per-file mode ---
    TOTAL=${#CLEAN_FILES[@]}
    IDX=0
    for FILE in "${CLEAN_FILES[@]}"; do
        IDX=$((IDX + 1))

        BASENAME=$(basename "$FILE")
        BASENAME_NOEXT="${BASENAME%.*}"

        if [ -n "$OUTPUT_DIR" ] && [ -d "$OUTPUT_DIR" ]; then
            OUTPUT="$OUTPUT_DIR/$BASENAME_NOEXT.pdf"
        else
            OUTPUT="${FILE%.*}.pdf"
        fi

        [ $TOTAL -gt 1 ] && show_progress $IDX $TOTAL "$BASENAME"

        CONVERT_ERR=$("${PYTHON_CMD[@]}" "$SCRIPT" "$FILE" -o "$OUTPUT" "${ARGS[@]}" 2>&1)

        if [ $? -eq 0 ]; then
            SUCCESS=$((SUCCESS + 1))
            PDF_FILES+=("$OUTPUT")
        else
            FAIL=$((FAIL + 1))
            LAST_ERR=$(echo "$CONVERT_ERR" | grep -E "(Error|Traceback)" | tail -1)
            [ -z "$LAST_ERR" ] && LAST_ERR=$(echo "$CONVERT_ERR" | tail -1)
            ERRORS="$ERRORS\n$(basename "$FILE"): $LAST_ERR"
        fi

        echo "$CONVERT_ERR" >> "$LOG"
    done
fi

# --- Result ---
if [ $SUCCESS -gt 0 ] && [ $FAIL -eq 0 ]; then
    if [ "$MERGE_MODE" = "yes" ]; then
        MSG="Merged PDF created: $(basename "${PDF_FILES[0]}")"
    elif [ $SUCCESS -eq 1 ]; then
        MSG="PDF created: $(basename "${PDF_FILES[0]}")"
    else
        MSG="PDFs created: $SUCCESS"
    fi
    osascript -e "display notification \"$MSG\" with title \"md2pdf\" sound name \"Glass\""

    if [ "$OPEN_PDF" = "yes" ]; then
        for PDF in "${PDF_FILES[@]}"; do
            open "$PDF"
        done
    fi

elif [ $SUCCESS -gt 0 ] && [ $FAIL -gt 0 ]; then
    osascript -e "display notification \"Created: $SUCCESS, errors: $FAIL\" with title \"md2pdf\" sound name \"Glass\""
    osascript -e "display alert \"md2pdf: Partial success\" message \"PDFs created: $SUCCESS\nErrors:$(echo -e "$ERRORS")\" as warning"

    if [ "$OPEN_PDF" = "yes" ]; then
        for PDF in "${PDF_FILES[@]}"; do
            open "$PDF"
        done
    fi
else
    ERR_DETAIL=$(echo -e "$ERRORS" | head -10)
    osascript -e "display alert \"md2pdf: Error\" message \"Could not create PDF.\n$ERR_DETAIL\" as critical"
fi
